local function num(v)
    v = tostring(v):gsub("%s", "")
    local n, s = v:match("([%d%.]+)(%a?)")
    n = tonumber(n) or 0
    if s == "K" or s == "k" then n *= 1e3
    elseif s == "M" or s == "m" then n *= 1e6
    elseif s == "B" or s == "b" then n *= 1e9
    elseif s == "T" or s == "t" then n *= 1e12 end
    return n
end

local function short(n)
    if n >= 1e12 then return string.format("%.2fT", n / 1e12)
    elseif n >= 1e9 then return string.format("%.2fB", n / 1e9)
    elseif n >= 1e6 then return string.format("%.2fM", n / 1e6)
    elseif n >= 1e3 then return string.format("%.2fK", n / 1e3) end
    return tostring(math.floor(n))
end

local function getTier(val)
    if val >= 1e12 then return "LEGENDARY", COLORS.gold, "👑"
    elseif val >= 1e9 then return "MYTHIC", COLORS.purple, "💎"
    elseif val >= 1e6 then return "EPIC", COLORS.blue, "🔮"
    elseif val >= 1e3 then return "RARE", COLORS.green, "⭐"
    else return "COMMON", COLORS.gray, "📦" end
end

